{
  "name": "finapp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm run dev --workspace=apps/api",
    "build:api": "npm run build --workspace=packages/db && npm run build --workspace=apps/api",
    "mobile": "npm run start --workspace=apps/mobile",
    "db:generate": "npm run generate --workspace=packages/db",
    "migrations": "npm run migrations --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db"
  },
  "engines": {
    "node": "24.15.0"
  }
}
