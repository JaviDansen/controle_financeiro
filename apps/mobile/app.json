{
  "expo": {
    "name": "FinApp",
    "slug": "finapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.finapp.controlefinanceiro"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-asset",
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-web-browser"
    ],
    "newArchEnabled": true,
    "scheme": "finapp",
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "202d559c-72ec-46be-b7f6-3e1a68a722cd"
      }
    }
  }
}
