# ─── Banco de dados (PostgreSQL na VPS) ───────────────────────────────────────
# Opção 1 — connection string completa (tem prioridade)
DATABASE_URL=postgresql://usuario:senha@host:porta/nome-do-banco?sslmode=disable

# Opção 2 — parâmetros individuais (usado como fallback se DATABASE_URL não estiver definida)
DATABASE_HOST=host-da-vps
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=sua-senha
DATABASE_NAME=finapp-db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_secreta_longa

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Mobile ───────────────────────────────────────────────────────────────────
# URL da API (Railway em produção, localhost em dev)
API_URL=http://localhost:3000

# ─── Trello MCP ───────────────────────────────────────────────────────────────
# Gere a API key em https://trello.com/app-key
# O token pode ser gerado a partir da mesma página da API key
TRELLO_API_KEY=sua_trello_api_key
TRELLO_TOKEN=seu_trello_token

# Opcional: define um board/workspace inicial para o MCP
TRELLO_BOARD_ID=
TRELLO_WORKSPACE_ID=

# ─── Google Service Account ───────────────────────────────────────────────────
# JSON da service account do Google Cloud (minificado em uma única linha)
# Crie em: https://console.cloud.google.com → IAM → Contas de serviço → Chaves
# Compartilhe o Google Doc/Drive com o client_email da service account
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
